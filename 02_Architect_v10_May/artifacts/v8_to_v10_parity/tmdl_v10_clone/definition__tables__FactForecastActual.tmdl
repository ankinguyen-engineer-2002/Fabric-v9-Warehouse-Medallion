/// Fact table containing forecast/actual quantity records by version, status, item, warehouse, customer group, horizon, and fiscal month. Used for detailed version and status analysis.
table FactForecastActual
	lineageTag: c1e4c663-cf6b-4b97-a0ac-07e779a0f402
	sourceLineageTag: [ForecastAccuracy_DW].[FactForecastActual]

	/// Item SKU identifier for joining to the product dimension.
	column ItemSKU
		dataType: string
		lineageTag: 70eb6686-0100-4e40-81d7-9a5e623f81f5
		sourceLineageTag: ItemSKU
		summarizeBy: none
		sourceColumn: ItemSKU

