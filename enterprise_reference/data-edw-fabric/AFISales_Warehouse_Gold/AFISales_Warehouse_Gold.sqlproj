<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build">
  <Sdk Name="Microsoft.Build.Sql" Version="0.1.12-preview" />
  <PropertyGroup>
    <Name>AFISales_Warehouse_Gold</Name>
    <ProjectGuid>{e9eabf84-fef3-470a-8487-2a14e93dad14}</ProjectGuid>
    <DSP>Microsoft.Data.Tools.Schema.Sql.SqlDwUnifiedDatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
    <TargetDatabaseSet>True</TargetDatabaseSet>
  </PropertyGroup>
  <ItemGroup>
    <Folder Include="AFISales_DW" />
    <Folder Include="AFISales_DW\Dimensions" />
    <Folder Include="AFISales_DW\Dimensions\Stored Procedures" />
    <Folder Include="AFISales_DW\Dimensions\Tables" />
    <Folder Include="AFISales_DW\Facts" />
    <Folder Include="AFISales_DW\Facts\Stored Procedures" />
    <Folder Include="AFISales_DW\Facts\Tables" />
    <Folder Include="AFISales_DW\Facts\Work Views" />
    <Folder Include="AFISales_Enh" />
    <Folder Include="AFISales_Enh\Stored Procedures" />
    <Folder Include="AFISales_Enh\Tables" />
    <Folder Include="AFISales_Enh\Views" />
    <Folder Include="AFISales_Wrk" />
    <Folder Include="AFISales_Wrk\Views" />
    <Folder Include="SecurityAcess" />
    <Folder Include="SecurityAcess\Schemas" />
    <Folder Include="SecurityAcess\Users" />
    <Folder Include="SSAS_AFISales_OLAP" />
  </ItemGroup>
  <ItemGroup>
    <SqlCmdVariable Include="Databricks">
      <Value>$(SqlCmdVar__9)</Value>
      <DefaultValue>pod_dev</DefaultValue>
    </SqlCmdVariable>
    <SqlCmdVariable Include="Distribution_Warehouse">
      <Value>$(SqlCmdVar__4)</Value>
      <DefaultValue>Distribution_Warehouse</DefaultValue>
    </SqlCmdVariable>
    <SqlCmdVariable Include="ETL_Framework">
      <Value>$(SqlCmdVar__8)</Value>
      <DefaultValue>ETL_Framework</DefaultValue>
    </SqlCmdVariable>
    <SqlCmdVariable Include="Finance_Warehouse_Gold">
      <Value>$(SqlCmdVar__14)</Value>
      <DefaultValue>Finance_Warehouse_Gold</DefaultValue>
    </SqlCmdVariable>
    <SqlCmdVariable Include="MasterData_Warehouse">
      <Value>$(SqlCmdVar__1)</Value>
      <DefaultValue>MasterData_Warehouse</DefaultValue>
    </SqlCmdVariable>
    <SqlCmdVariable Include="Quality_Warehouse">
      <Value>$(SqlCmdVar__13)</Value>
      <DefaultValue>Quality_Warehouse</DefaultValue>
    </SqlCmdVariable>
    <SqlCmdVariable Include="Wholesale_Warehouse">
      <Value>$(SqlCmdVar__2)</Value>
      <DefaultValue>Wholesale_Warehouse</DefaultValue>
    </SqlCmdVariable>
    <SqlCmdVariable Include="Source_Data">
      <Value>$(SqlCmdVar__15)</Value>
      <DefaultValue>Source_Data</DefaultValue>
    </SqlCmdVariable>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Databricks\Databricks.sqlproj">
      <Name>Databricks</Name>
      <Project>{932FA6DF-2F2D-4496-A408-C1C1257CC95E}</Project>
      <Private>True</Private>
      <SuppressMissingDependenciesErrors>False</SuppressMissingDependenciesErrors>
      <DatabaseSqlCmdVariable>Databricks</DatabaseSqlCmdVariable>
    </ProjectReference>
    <ProjectReference Include="..\Distribution_Warehouse\Distribution_Warehouse.sqlproj">
      <Name>Distribution_Warehouse</Name>
      <Project>{8215A27C-42A7-44E9-BC2C-B8BDFC269B41}</Project>
      <Private>True</Private>
      <SuppressMissingDependenciesErrors>False</SuppressMissingDependenciesErrors>
      <DatabaseSqlCmdVariable>Distribution_Warehouse</DatabaseSqlCmdVariable>
    </ProjectReference>
    <ProjectReference Include="..\ETL_Framework\ETL_Framework.sqlproj">
      <Name>ETL_Framework</Name>
      <Project>{339cfc5c-5700-42f4-82c3-20c6d6af0ee6}</Project>
      <Private>True</Private>
      <SuppressMissingDependenciesErrors>False</SuppressMissingDependenciesErrors>
      <DatabaseSqlCmdVariable>ETL_Framework</DatabaseSqlCmdVariable>
    </ProjectReference>
    <ProjectReference Include="..\MasterData_Warehouse\MasterData_Warehouse.sqlproj">
      <Name>MasterData_Warehouse</Name>
      <Project>{0212F551-B765-4E23-AAB4-2EB5C0D50000}</Project>
      <Private>True</Private>
      <SuppressMissingDependenciesErrors>False</SuppressMissingDependenciesErrors>
      <DatabaseSqlCmdVariable>MasterData_Warehouse</DatabaseSqlCmdVariable>
    </ProjectReference>
    <ProjectReference Include="..\Quality_Warehouse\Quality_Warehouse.sqlproj">
      <Name>Quality_Warehouse</Name>
      <Project>{80E8376F-F8F9-4707-84DC-94A2BC6939A4}</Project>
      <Private>True</Private>
      <SuppressMissingDependenciesErrors>False</SuppressMissingDependenciesErrors>
      <DatabaseSqlCmdVariable>Quality_Warehouse</DatabaseSqlCmdVariable>
    </ProjectReference>
    <ProjectReference Include="..\Wholesale_Warehouse\Wholesale_Warehouse.sqlproj">
      <Name>Wholesale_Warehouse</Name>
      <Project>{221120FE-3892-40E7-B573-1523994565BB}</Project>
