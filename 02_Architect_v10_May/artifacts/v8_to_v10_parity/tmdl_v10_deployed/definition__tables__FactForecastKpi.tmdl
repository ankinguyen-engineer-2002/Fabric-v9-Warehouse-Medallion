/// Primary KPI fact table for forecast accuracy. Stores forecast, actual, naive forecast, signed error, absolute error, squared error, and validation flags at item-warehouse-horizon-fiscal month grain.
table FactForecastKpi
	lineageTag: fdf1fc38-8ba5-450e-be33-10c82fa6fd4f
	sourceLineageTag: [ForecastAccuracy_DW].[FactForecastKpi]

	/// Item SKU identifier for joining to the product dimension and evaluating KPI performance at item level.
