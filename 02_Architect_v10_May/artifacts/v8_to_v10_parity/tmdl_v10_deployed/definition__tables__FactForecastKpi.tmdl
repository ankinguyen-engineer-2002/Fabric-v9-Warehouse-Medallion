		dataType: string
		lineageTag: 99157bbf-243c-4b61-939a-21e03c69016a
		sourceLineageTag: ItemSKU
		summarizeBy: none
		sourceColumn: ItemSKU

		annotation SummarizationSetBy = Automatic

