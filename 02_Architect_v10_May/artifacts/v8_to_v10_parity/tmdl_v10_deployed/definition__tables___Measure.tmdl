			        SUM('FactForecastActual'[Qty]),
			        'FactForecastActual'[StatusCode] = "Open Order"
			    )
			```
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 5d7fd4c2-3de2-4e19-acdb-4341da335511

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Quantity for the latest available forecast version in the selected context. Used for version comparison visuals.
	measure Qty_Latest_V =
			
			VAR VersionTable =
			    FILTER(
			        ALLSELECTED('FactForecastActual'),
			        LEFT('FactForecastActual'[VersionName], 2) = "V "
			    )
			
			VAR LatestVersion =
			    CALCULATE(
			        MAX('FactForecastActual'[VersionName]),
			        VersionTable
			    )
			
			VAR YearText = MID(LatestVersion, 3, 4)
			VAR MonthText = RIGHT(LatestVersion, 2)
			
			VAR DATE_VERSION =
			    DATE(
			        VALUE(YearText),
			        VALUE(MonthText),
			        1
			    )
			
			RETURN
			IF(
			    MAX('FactForecastActual'[FSCMonthLast]) >= DATE_VERSION,
			    CALCULATE(
			        SUM('FactForecastActual'[Qty]),
			        'FactForecastActual'[VersionName] = LatestVersion
			    ),
			    BLANK()
			)
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 1c1248a2-a8d4-4210-8a77-af627008d69e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

