/// TMDL (Tabular Model Definition Language) — Power BI semantic model for Inventory Health
/// Built on top of SupplyChain_Gold_Warehouse via DirectLake. v10 schema-rewritten from
/// deliverable v1 (`gold` → `InventoryHealth_DW` on 2026-05-18).
///
/// Workspace: SupplyChain Dev (c8d9fc83-18b6-4e1d-8264-0b49eed36fe0)
/// Warehouse: SupplyChain_Gold_Warehouse (98e2a911-...)
/// Schema:    InventoryHealth_DW
///
/// 5 conformed dims + 2 fact tables (snapshot health + risk forward) + 30 measures.
/// All 7 tables live in InventoryHealth_DW schema (DirectLake-bound to physical tables
/// produced by pl_sc_gold pipeline via Meta.usp_GenericLoad CTAS from corresponding v_*).
///
/// To deploy:
///   1. Open Power BI Desktop → "New report" → "Direct Lake on OneLake"
///   2. Point to workspace > SupplyChain_Gold_Warehouse
///   3. Select 8 tables: DimDate, DimItem, DimWarehouse, DimVendor, DimRuleVersion,
///      CogsRollingHelper (hidden), FactInventoryHealthSnapshot, FactInventoryRiskForward
///   4. Apply this TMDL via Tabular Editor (or use as reference and define manually)

model InventoryHealth
    culture: en-US
    defaultPowerBIDataSourceVersion: powerBI_V3

/// ═══════════════════════════════════════════════════════
/// TABLE: DimDate
/// ═══════════════════════════════════════════════════════
table DimDate
    lineageTag: dim-date

    column DateKey
        dataType: int64
        isKey
        summarizeBy: none

    column CalendarDate
        dataType: dateTime
        formatString: yyyy-mm-dd
        summarizeBy: none

    column WeekEndingDate
        dataType: dateTime
        formatString: yyyy-mm-dd
        summarizeBy: none

    column FiscalWeek
        dataType: int64

    column FiscalWeekIndicator
        dataType: int64

    column FiscalMonth
        dataType: int64

    column FiscalMonthYear
        dataType: int64

    column IsCurrentDate
        dataType: int64
        summarizeBy: none

    column IsCurrentWeek
        dataType: int64
        summarizeBy: none

    column IsMonthEnd
        dataType: int64
        summarizeBy: none

    partition DimDate-prt = entity
        mode: directLake
        source = entity
            entityName: DimDate
            schemaName: InventoryHealth_DW


/// ═══════════════════════════════════════════════════════
/// TABLE: DimItem
/// ═══════════════════════════════════════════════════════
table DimItem
    lineageTag: dim-item

    column ItemSku
        dataType: string
        isKey
        summarizeBy: none

    column ItemDescription
        dataType: string

    column ItemClassCode
        dataType: string

    column ItemClassName
        dataType: string

    column CategoryName
        dataType: string

    column CollectiveClass
        dataType: string

    column SeriesNumber
        dataType: string

    column SeriesName
        dataType: string

    column AfiItemStatus
        dataType: string

    column LifecycleStatus
        dataType: string

    column PrimaryVendorNumber
        dataType: string

    column PrimaryVendorName
        dataType: string

    column Cubes
        dataType: decimal
        formatString: 0.0000
        summarizeBy: none

    column FobArcPrice
        dataType: decimal
        formatString: $#,##0.00
        summarizeBy: none

    column IsFinishedGoodsItem
        dataType: int64
        summarizeBy: none

    column DiscontinuedFlag
        dataType: int64
        summarizeBy: none

    column NewItemFlag
        dataType: int64
        summarizeBy: none

    column UnavailableFlag
        dataType: int64
        summarizeBy: none

    partition DimItem-prt = entity
        mode: directLake
        source = entity
            entityName: DimItem
            schemaName: InventoryHealth_DW


/// ═══════════════════════════════════════════════════════
/// TABLE: DimWarehouse
/// ═══════════════════════════════════════════════════════
table DimWarehouse
    lineageTag: dim-warehouse

    column WarehouseCode
        dataType: string
        isKey
        summarizeBy: none

    column WarehouseName
        dataType: string

    column WarehouseType
        dataType: string

    column SellableWarehouseFlag
        dataType: int64
        summarizeBy: none

    column IntransitWarehouseCode
        dataType: string

    column IsFinishedGoodsWarehouse
        dataType: int64
        summarizeBy: none

    column IsManufacturingWarehouse
        dataType: int64
        summarizeBy: none

    column TotalAvailableWarehouseCube
        dataType: decimal
        formatString: 0.00
        summarizeBy: sum

    partition DimWarehouse-prt = entity
        mode: directLake
        source = entity
            entityName: DimWarehouse
            schemaName: InventoryHealth_DW


/// ═══════════════════════════════════════════════════════
/// TABLE: DimVendor
/// ═══════════════════════════════════════════════════════
table DimVendor
    lineageTag: dim-vendor

    column VendorNumber
        dataType: string
        isKey
        summarizeBy: none

    column VendorName
        dataType: string

    partition DimVendor-prt = entity
        mode: directLake
        source = entity
            entityName: DimVendor
            schemaName: InventoryHealth_DW


/// ═══════════════════════════════════════════════════════
/// TABLE: DimRuleVersion
/// ═══════════════════════════════════════════════════════
table DimRuleVersion
    lineageTag: dim-rule-version

    column RuleVersionKey
        dataType: int64
        isKey
        summarizeBy: none

    column RuleName
        dataType: string

    column EffectiveStartDate
        dataType: dateTime

    column EffectiveEndDate
        dataType: dateTime

    column RuleDescription
        dataType: string

    partition DimRuleVersion-prt = entity
        mode: directLake
        source = entity
            entityName: DimRuleVersion
            schemaName: InventoryHealth_DW


/// ═══════════════════════════════════════════════════════
/// TABLE: FactInventoryHealthSnapshot (current + weekly trend)
/// ═══════════════════════════════════════════════════════
table FactInventoryHealthSnapshot
    lineageTag: fact-inv-health

    column ItemSku
        dataType: string

    column WarehouseCode
        dataType: string

    column SnapshotDate
        dataType: dateTime

    column SnapshotType
        dataType: string

    column WeekEndingDate
        dataType: dateTime

    column DateKey
        dataType: int64
        summarizeBy: none

    column FiscalMonth
        dataType: int64

    column FiscalMonthYear
        dataType: int64

    column IsLatestSnapshot
        dataType: int64
        summarizeBy: none

    column OnHandQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column TransferInInTransitQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column POOnOrderQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column POInTransitQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column MOOnOrderQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column InTransitQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column OnOrderQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column AwdQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: average

    column AwdSource
        dataType: string

    column WeeksOfSupply
        dataType: decimal
        formatString: 0.00
        summarizeBy: average

    column SafetyStockTargetQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column SafetyStockMultiple
        dataType: decimal
        formatString: 0.00
        summarizeBy: average

    column InventoryClassification
        dataType: string

    column StandardCost
        dataType: decimal
        formatString: $#,##0.0000
        summarizeBy: average

    column FobArcPrice
        dataType: decimal
        formatString: $#,##0.00
        summarizeBy: average

    column Cubes
        dataType: decimal
        formatString: 0.0000
        summarizeBy: average

    column InventoryValueAtCost
        dataType: decimal
        formatString: $#,##0.00
        summarizeBy: sum

    column InventoryValueAtRevenue
        dataType: decimal
        formatString: $#,##0.00
        summarizeBy: sum

    column UsedStorageCube
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column PeriodCogs
        dataType: decimal
        formatString: $#,##0.00
        summarizeBy: sum

    // M3 FIX (2026-05-17): renamed Cogs52W → Cogs52M (monthly grain — 52 PRECEDING rows = 52 months)
    column Cogs52M
        dataType: decimal
        formatString: $#,##0.00
        summarizeBy: sum

    column AverageInventoryValueAtCost
        dataType: decimal
        formatString: $#,##0.00
        summarizeBy: average

    column ObsoleteValue
        dataType: decimal
        formatString: $#,##0.00
        summarizeBy: sum

    column LastInvoiceDate
        dataType: dateTime

    column LifecycleStatus
        dataType: string

    column InactiveFlag
        dataType: int64
        summarizeBy: none

    column SlobFlag
        dataType: int64
        summarizeBy: none

    column NoMovementFlag
        dataType: int64
        summarizeBy: none

    column UnavailableFlag
        dataType: int64
        summarizeBy: none

    column OnHoldFlag
        dataType: int64
        summarizeBy: none

    column OnHoldQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column RuleVersionKey
        dataType: int64
        summarizeBy: none

    partition FactInventoryHealthSnapshot-prt = entity
        mode: directLake
        source = entity
            entityName: FactInventoryHealthSnapshot
            schemaName: InventoryHealth_DW


/// ═══════════════════════════════════════════════════════
/// TABLE: FactInventoryRiskForward (forward projection)
/// ═══════════════════════════════════════════════════════
table FactInventoryRiskForward
    lineageTag: fact-risk-forward

    column ItemSku
        dataType: string

    column WarehouseCode
        dataType: string

    column WeekEndingDate
        dataType: dateTime

    column DateKey
        dataType: int64
        summarizeBy: none

    column BeginningBalanceQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column FirmDemandQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column NetForecastQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column FirmPurchaseOrderQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column PlannedPurchaseOrderQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column OnOrderTransferInQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column ShippableInventoryQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column SafetyStockTargetQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column MonthsOfSupply
        dataType: decimal
        formatString: 0.00
        summarizeBy: average

    column ExpectedDemand14DQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column Inbound14DQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column AllocatedDemandQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column ATPQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column ATPInStockFlag
        dataType: int64
        summarizeBy: none

    column ShippableInStockFlag
        dataType: int64
        summarizeBy: none

    column SINegQty
        dataType: decimal
        formatString: 0.0000
        summarizeBy: sum

    column RevenueAtRiskValue
        dataType: decimal
        formatString: $#,##0.00
        summarizeBy: sum

    column WeekFourFlag
        dataType: int64
        summarizeBy: none

    column FobArcPrice
        dataType: decimal
        formatString: $#,##0.00
        summarizeBy: average

    column RuleVersionKey
        dataType: int64
        summarizeBy: none

    partition FactInventoryRiskForward-prt = entity
        mode: directLake
        source = entity
            entityName: FactInventoryRiskForward
            schemaName: InventoryHealth_DW


/// ═══════════════════════════════════════════════════════
/// RELATIONSHIPS
/// ═══════════════════════════════════════════════════════

relationship DimDate_to_FactHealth
    fromColumn: FactInventoryHealthSnapshot.DateKey
    toColumn:   DimDate.DateKey
    crossFilteringBehavior: oneDirection

relationship DimDate_to_FactRisk
    fromColumn: FactInventoryRiskForward.DateKey
    toColumn:   DimDate.DateKey
    crossFilteringBehavior: oneDirection

relationship DimItem_to_FactHealth
    fromColumn: FactInventoryHealthSnapshot.ItemSku
    toColumn:   DimItem.ItemSku
    crossFilteringBehavior: oneDirection

relationship DimItem_to_FactRisk
    fromColumn: FactInventoryRiskForward.ItemSku
    toColumn:   DimItem.ItemSku
    crossFilteringBehavior: oneDirection

relationship DimWarehouse_to_FactHealth
    fromColumn: FactInventoryHealthSnapshot.WarehouseCode
    toColumn:   DimWarehouse.WarehouseCode
    crossFilteringBehavior: oneDirection

relationship DimWarehouse_to_FactRisk
    fromColumn: FactInventoryRiskForward.WarehouseCode
    toColumn:   DimWarehouse.WarehouseCode
    crossFilteringBehavior: oneDirection

relationship DimVendor_to_DimItem
    fromColumn: DimItem.PrimaryVendorNumber
    toColumn:   DimVendor.VendorNumber
    crossFilteringBehavior: oneDirection

relationship DimRuleVersion_to_FactHealth
    fromColumn: FactInventoryHealthSnapshot.RuleVersionKey
    toColumn:   DimRuleVersion.RuleVersionKey
    crossFilteringBehavior: oneDirection

relationship DimRuleVersion_to_FactRisk
    fromColumn: FactInventoryRiskForward.RuleVersionKey
    toColumn:   DimRuleVersion.RuleVersionKey
    crossFilteringBehavior: oneDirection
