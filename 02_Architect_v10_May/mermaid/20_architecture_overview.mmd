flowchart TB
    subgraph EXT["Enterprise_Data Workspace"]
        SRC["Upstream Source Products<br/>EDW / Codis / MasterData / Customers"]
    end

    subgraph SC["SupplyChain Dev Workspace"]
        subgraph BRONZE["BRONZE — Logical Access Layer"]
