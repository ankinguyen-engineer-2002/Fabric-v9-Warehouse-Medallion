<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build">
  <Sdk Name="Microsoft.Build.Sql" Version="0.1.12-preview" />
  <PropertyGroup>
    <Name>Retail_Warehouse</Name>
    <ProjectGuid>{E49E0E30-8338-4E2A-A71F-F0A0FFD82C61}</ProjectGuid>
    <DSP>Microsoft.Data.Tools.Schema.Sql.SqlDwUnifiedDatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
  </PropertyGroup>
  <ItemGroup>
    <SqlCmdVariable Include="Databricks_Retail">
      <Value>$(SqlCmdVar__1)</Value>
      <DefaultValue>Databricks_Retail</DefaultValue>
    </SqlCmdVariable>
    <SqlCmdVariable Include="Databricks">
      <Value>$(SqlCmdVar__3)</Value>
      <DefaultValue>Databricks</DefaultValue>
    </SqlCmdVariable>
    <SqlCmdVariable Include="ETL_Framework">
      <Value>$(SqlCmdVar__2)</Value>
      <DefaultValue>ETL_Framework</DefaultValue>
    </SqlCmdVariable>
    <SqlCmdVariable Include="Source_Data">
      <Value>$(SqlCmdVar__4)</Value>
      <DefaultValue>Source_Data</DefaultValue>
    </SqlCmdVariable>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\ETL_Framework\ETL_Framework.sqlproj">
      <Name>ETL_Framework</Name>
      <Project>{339cfc5c-5700-42f4-82c3-20c6d6af0ee6}</Project>
      <Private>True</Private>
      <SuppressMissingDependenciesErrors>False</SuppressMissingDependenciesErrors>
      <DatabaseSqlCmdVariable>ETL_Framework</DatabaseSqlCmdVariable>
    </ProjectReference>
    <ProjectReference Include="..\Source_Data\Source_Data.sqlproj">
      <Name>Source_Data</Name>
      <Project>{3DBE2BBF-5B6C-4112-A397-01A504607CD0}</Project>
      <Private>True</Private>
      <SuppressMissingDependenciesErrors>False</SuppressMissingDependenciesErrors>
      <DatabaseSqlCmdVariable>Source_Data</DatabaseSqlCmdVariable>
    </ProjectReference>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.SqlServer.Dacpacs.Master">
      <Version>160.0.0</Version>
      <GeneratePathProperty>True</GeneratePathProperty>
      <DatabaseVariableLiteralValue>master</DatabaseVariableLiteralValue>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <Build Remove="Retail_OOM_Wrk\Functions\**" />
  </ItemGroup>
  <ItemGroup>
    <Build Remove="Retail_Sales\Functions\**" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Retail_Traffic" />
    <Folder Include="Retail_Traffic\Stored Procedures" />
    <Folder Include="Retail_Traffic\Tables" />
    <Folder Include="Retail_Traffic_Wrk" />
    <Folder Include="Retail_Traffic_Wrk\Tables" />
  </ItemGroup>
  <Target Name="BeforeBuild">
    <Delete Files="$(BaseIntermediateOutputPath)\project.assets.json" />
  </Target>
</Project>