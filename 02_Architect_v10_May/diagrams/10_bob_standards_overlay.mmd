flowchart LR
    subgraph BOB["Bob SQL DW Standards"]
        SCH["Schema taxonomy<br/>WRK / ENH / DW / Audit / Archive"]
        NAM["Naming rules<br/>PascalCase Silver and Gold<br/>Bronze mimics source"]
        TD["TableDictionary standard<br/>metadata, PK, refresh SLA"]
        SEC["Schema/security standard<br/>least privilege and mapping"]
        GOV["Design approval<br/>Rakesh / assigned approver"]
        BI["Legacy BI view rule<br/>adapt for Fabric Direct Lake"]
        PERF["Performance and quality<br/>PK, stats intent, duplicate tests"]
        EDWSTD["External/source fallback<br/>object-level approval<br/>ADR-002"]
    end

    subgraph V10["Fabric v10 Supply Chain Architecture"]
        BRZ["Logical Bronze<br/>Enterprise_Access_Lakehouse shortcuts"]
        WRK["Exception Staging<br/>Staging_WRK / BronzeMirror_WRK"]
        EDW["EDW Supplement<br/>2 ExitCandidate / 2 NotReady<br/>retire only after validation"]
        ENH["Domain Silver<br/>ForecastHistory / InventoryHistory"]
        GWD["Gold Physical Tables<br/>Fact / Dim tables in Gold Warehouse"]
        SEM["Power BI Semantic Model<br/>Direct Lake"]
        META["v9 Meta Control Plane<br/>sp_registry + vw_table_dictionary"]
    end

    SCH --> WRK
    SCH --> ENH
    SCH --> GWD
    NAM --> BRZ
    NAM --> ENH
    NAM --> GWD
    TD --> META
    SEC --> META
    GOV --> META
    PERF --> META
    EDWSTD --> EDW
    EDW --> WRK
    BI -->|"do not apply literally"| GWD
    GWD -->|"Direct Lake physical tables"| SEM
    BRZ -->|"direct by default"| ENH
    BRZ -->|"stage by exception"| WRK
    WRK --> ENH
    ENH --> GWD
    META -.controls.-> BRZ
    META -.controls.-> WRK
    META -.controls.-> ENH
    META -.controls.-> GWD
    META -.refresh + validate.-> SEM

    class SCH,NAM,TD,SEC,GOV,BI,PERF,EDWSTD standard
    class BRZ bronze
    class WRK,EDW staging
    class ENH silver
    class GWD,SEM gold
    class META control

    classDef standard fill:#E8EEF7,stroke:#50627A,color:#111111
    classDef bronze fill:#B86B2B,stroke:#6B3A12,color:#FFFFFF
    classDef staging fill:#D9822B,stroke:#8A4A0A,color:#FFFFFF
    classDef silver fill:#C7CCD6,stroke:#687080,color:#111111
    classDef gold fill:#F2C94C,stroke:#9A6B00,color:#111111
    classDef control fill:#0B3D91,stroke:#06275F,color:#FFFFFF
