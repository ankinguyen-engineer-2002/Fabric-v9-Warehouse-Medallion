	/// Root mean squared naive forecast error across valid observations. Used to compare the naive baseline against the consensus forecast.
	measure RMSE_Naive = SQRT ( DIVIDE ( SUM ( FactForecastKpi[QtySquaredNaiveFcstError] ), SUM ( FactForecastKpi[ValidObsFlag] ) ) )
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: b75b770d-1819-4369-aa85-fa7ba12b60fa

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Forecast accuracy for the prior fiscal quarter comparison. For multi-month selections, compares against the same-length window shifted back one fiscal quarter.
	measure Pct_ForecastAccuracy_lq =
			VAR CurrentMonths =
			    VALUES(DimCalendar[FSCMonthYearNum])
			VAR MonthCount =
			    COUNTROWS(CurrentMonths)
			VAR CurrentQuarters =
			    VALUES(DimCalendar[FSCQuarterYearNum])
			VAR PrevQuarter =
			    SELECTCOLUMNS(
			        CurrentQuarters,
			        "num_fsc_quarter_year",
			            VAR CurrentQuarterKey = DimCalendar[FSCQuarterYearNum]
			            RETURN
			                MAXX(
			                    FILTER(
			                        ALL(DimCalendar[FSCQuarterYearNum]),
			                        DimCalendar[FSCQuarterYearNum] < CurrentQuarterKey
			                    ),
			                    DimCalendar[FSCQuarterYearNum]
			                )
			    )
			VAR RollingPrevQuarterMonths =
			    SELECTCOLUMNS(
			        CurrentMonths,
			        "num_fsc_month_year",
			            VAR CurrentMonthKey = DimCalendar[FSCMonthYearNum]
			            VAR PriorThreeMonths =
			                TOPN(
			                    3,
			                    FILTER(
			                        ALL(DimCalendar[FSCMonthYearNum]),
			                        DimCalendar[FSCMonthYearNum] < CurrentMonthKey
			                    ),
			                    DimCalendar[FSCMonthYearNum], DESC
			                )
			            RETURN
			                MINX(
			                    PriorThreeMonths,
			                    DimCalendar[FSCMonthYearNum]
			                )
			    )
			RETURN
			IF(
			    MonthCount = 1,
			    CALCULATE(
			        [Pct_ForecastAccuracy],
			        REMOVEFILTERS(DimCalendar),
			        TREATAS(
			            PrevQuarter,
			            DimCalendar[FSCQuarterYearNum]
			        )
			    ),
			    CALCULATE(
			        [Pct_ForecastAccuracy],
			        REMOVEFILTERS(DimCalendar),
			        TREATAS(
			            RollingPrevQuarterMonths,
			            DimCalendar[FSCMonthYearNum]
			        )
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: db541397-4f0c-4a02-86b0-940ad02e0cec

	/// Static background color value used for RMSE table visual conditional formatting.
	measure RMSE_Table_Background_Color = "#D9D9D9"
		displayFolder: 3. Narrative
		lineageTag: 2871e751-44e6-43ff-86c3-ddc0382899f6

	/// Returns the current date for report refresh or display context.
	measure UpdatedTime = TODAY()
