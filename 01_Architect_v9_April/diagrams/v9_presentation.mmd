flowchart TD

    %% ══════════════════════════════════════════════════════════════════════
    %% TEMPLATE — Presentation Edition
    %% For: DA, Business Users, Leadership, Stakeholders
    %%
    %% READ: Top → Bottom is the execution flow
    %% Pipeline drives everything — data layers are INSIDE the pipeline
    %% Customize: replace {placeholders} with your project values
    %% ══════════════════════════════════════════════════════════════════════

    %% ============ TITLE ============
    subgraph TITLE["🏗️ {Project_Name} — Warehouse Architecture"]
      direction LR
      T_SUB["Microsoft Fabric · Pure T-SQL · Metadata-Driven<br/>{N} tables · {N} pipelines · ~{N} min full refresh · {N}B total rows<br/><br/>📖 Read top → bottom: pipeline drives data through each layer"]
    end

    %% ══════════════════════════════════════════════════════════════
    %% ① DATA SOURCES
    %% ══════════════════════════════════════════════════════════════
    subgraph SRC["① DATA SOURCES — Enterprise Lakehouse"]
      direction LR
      SRC_1["📋 {Source_Group_1}<br/>{N}M rows"]
      SRC_2["📊 {Source_Group_2}<br/>{N}B rows"]
      SRC_3["📦 {Source_Group_3}<br/>{N}M rows"]
      SRC_4["📅 Reference Data<br/>{N} dim tables"]
    end

    %% ══════════════════════════════════════════════════════════════
    %% ② PIPELINE — the engine that drives everything
    %% ══════════════════════════════════════════════════════════════
    subgraph PL_MASTER["② PIPELINE — pl_master · runs daily {HH}:00 {TZ} · concurrency=1"]
      direction TB

      PL_START["❶ Start & Log"]

      PL_DISCOVER["❷ Discover Projects<br/>Lookup DISTINCT project<br/>from registry"]

      subgraph PL_FOREACH["❸ ForEach Project — PARALLEL · N marts simultaneously"]
        direction TB

        subgraph PL_MART["pl_mart — per project: bronze → silver → gold"]
          direction TB

          subgraph STEP_BRZ["❸a Load Bronze — {N} tables parallel"]
            direction LR
            BRZ_DESC["Raw mirror from source<br/>No transforms · batch={N}<br/>~{N}B rows · ~{N} min"]
          end

          DQ_BRZ["🛡️ DQ Gate · {N} rules · ⏸ deactivated"]

          subgraph STEP_SLV["❸b Load Silver — {N} tables · DAG wave order"]
            direction LR

            subgraph W0["❶ Wave 0 — base tables · parallel"]
              direction LR
              S_A["{concept_A}<br/>{N}M"]
              S_B["{concept_B}<br/>{N}M"]
              S_C["{concept_C}<br/>{N}K"]
            end

            subgraph W1["❷ Wave 1 — derived · parallel"]
              direction LR
              S_D["{concept_D}<br/>{N}K"]
              S_E["{concept_E}<br/>{N}M"]
              S_F["{concept_F}<br/>{N}K"]
            end

            subgraph W2["❸ Wave 2 — deepest"]
              S_G["{concept_G}<br/>{N}K"]
            end

          end

          DQ_SLV["🛡️ DQ Gate · {N} rules · ⏸ deactivated"]

          subgraph STEP_GLD["❸c Load Gold — {N} fact tables"]
            direction LR
            G_F1["gld_fact_{subject_1}<br/>{N}M rows"]
            G_F2["gld_fact_{subject_2}<br/>{N}M rows"]
          end

          DQ_GLD["🛡️ DQ Gate · {N} rules · ⏸ deactivated"]

          %% Mart internal flow
          STEP_BRZ ==> DQ_BRZ ==> STEP_SLV ==> DQ_SLV ==> STEP_GLD ==> DQ_GLD

        end
      end

      PL_FINAL["❹ Finalize<br/>Build lineage · Update log"]

      PL_REFRESH["❺ Refresh Semantic Model"]

      %% Master flow
      PL_START ==> PL_DISCOVER ==> PL_FOREACH ==> PL_FINAL ==> PL_REFRESH
    end

    %% DQ fail path
    DQ_STOP["🚫 CRITICAL fail → STOP<br/>Bad data never reaches reports"]
    DQ_BRZ -.->|"fail"| DQ_STOP
    DQ_SLV -.->|"fail"| DQ_STOP
    DQ_GLD -.->|"fail"| DQ_STOP

    %% Silver DAG dependencies
    S_A ==>|"feeds"| S_D
    S_C ==>|"feeds"| S_D
    S_A ==> S_E
    S_C ==> S_F
    S_D ==>|"feeds"| S_G

    %% ══════════════════════════════════════════════════════════════
    %% ③ SEMANTIC MODEL + REPORTS
    %% ══════════════════════════════════════════════════════════════
    subgraph CON["③ REPORTS — What end users see"]
      direction LR
      CON_SM["{SM_Name}<br/>Semantic Model<br/>{N} dims + {N} facts<br/>~{N} DAX measures<br/>Direct Lake"]
      CON_PBI["📊 Dashboards<br/>Real-time · No import<br/>Auto-refreshed daily"]
      CON_SM ==> CON_PBI
    end

    %% ══════════════════════════════════════════════════════════════
    %% MAIN FLOW CONNECTIONS
    %% ══════════════════════════════════════════════════════════════
    SRC ==>|"3-part naming"| STEP_BRZ
    PL_REFRESH -.->|"auto-refresh"| CON_SM

    %% ══════════════════════════════════════════════════════════════
    %% SCORECARD
    %% ══════════════════════════════════════════════════════════════
    subgraph SCORE["📋 WHAT WE'VE BUILT — {N} Features · Enterprise ~{N}%"]
      direction TB

      subgraph SCORE_ON["✅ Active in Production ({N})"]
        direction LR
        A1["Generic SP Engine<br/>1 SP · 8 load patterns"]
        A2["Metadata-Driven<br/>Add table = 2 SQL stmts"]
        A3["DAG Orchestration<br/>Auto waves · parallel"]
        A4["Auto Lineage<br/>{N} edges · every run"]
        A5["Smart Scheduling<br/>Cron + smart skip"]
        A6["Full Logging<br/>SP + pipeline · {N} TZ"]
        A7["Enterprise Aligned<br/>TableDict {N}/{N} · LP 8/8"]
        A8["Multi-Mart Ready<br/>N projects parallel"]
      end

      subgraph SCORE_PAUSE["⏸ Built & Tested · Off for Speed ({N})"]
        direction LR
        B1["DQ Engine<br/>{N} types · {N} rules"]
        B2["DQ Gates<br/>Between every layer"]
        B3["DQ Expansion<br/>{N} more rules · 1 SQL"]
      end

      subgraph SCORE_READY["🔧 Created · Pending Activation ({N})"]
        direction LR
        C1["Perf Baseline<br/>{N} SPs baselined"]
        C2["Cost Monitor<br/>CU per run"]
        C3["Schema Contracts<br/>{N} cols tracked"]
      end

      subgraph SCORE_BLOCK["⚠ Blocked ({N})"]
        direction LR
        D1["{Feature_1}<br/>{blocker}"]
        D2["{Feature_2}<br/>{blocker}"]
      end
    end

    %% ══════════════════════════════════════════════════════════════
    %% PERFORMANCE + ROADMAP
    %% ══════════════════════════════════════════════════════════════
    subgraph BOTTOM[" "]
      direction LR

      subgraph PERF["⚡ PERFORMANCE"]
        direction LR
        P1["🕐 ~{N} min<br/>{N} tables"]
        P2["📊 {N}B<br/>total rows"]
        P3["✅ {N}/{N}<br/>0 failures"]
        P4["🔄 ~{N} min<br/>smart skip"]
        P5["🛡️ ~{N} min<br/>DQ on"]
        P1 ~~~ P2 ~~~ P3 ~~~ P4 ~~~ P5
      end

      subgraph ROAD["🗺️ ROADMAP"]
        direction LR
        R_DEV["DEV ✅"]
        R_TEST["TEST ⏳"]
        R_PROD["PROD ⏳"]
        R_DEV ==>|"deploy"| R_TEST ==>|"approve"| R_PROD
      end
    end

    %% ════════════════════════════════════════════════
    %% STYLES
    %% ════════════════════════════════════════════════
    classDef title fill:#1E293B,stroke:#1E293B,color:#F8FAFC,stroke-width:2px
    classDef source fill:#DBEAFE,stroke:#2563EB,color:#1E3A5F,stroke-width:2px
    classDef bronze fill:#FED7AA,stroke:#EA580C,color:#7C2D12,stroke-width:2px
    classDef silver fill:#E9D5FF,stroke:#9333EA,color:#581C87,stroke-width:2px
    classDef gold fill:#FDE68A,stroke:#D97706,color:#78350F,stroke-width:2px
    classDef consume fill:#C7D2FE,stroke:#6366F1,color:#312E81,stroke-width:2px
    classDef pipeline fill:#FBCFE8,stroke:#DB2777,color:#831843,stroke-width:2px
    classDef dq fill:#FECDD3,stroke:#E11D48,color:#881337,stroke-width:2px
    classDef stop fill:#FEE2E2,stroke:#DC2626,color:#991B1B,stroke-width:2px
    classDef active fill:#BBF7D0,stroke:#16A34A,color:#14532D,stroke-width:2px
    classDef paused fill:#FEF08A,stroke:#CA8A04,color:#713F12,stroke-width:2px
    classDef ready fill:#E0E7FF,stroke:#6366F1,color:#312E81,stroke-width:1px
    classDef blocked fill:#FECACA,stroke:#EF4444,color:#7F1D1D,stroke-width:2px
    classDef perf fill:#F0FDF4,stroke:#16A34A,color:#14532D,stroke-width:2px
    classDef road fill:#F5F3FF,stroke:#7C3AED,color:#4C1D95,stroke-width:2px

    class T_SUB title
    class SRC_1,SRC_2,SRC_3,SRC_4 source
    class BRZ_DESC bronze
    class S_A,S_B,S_C,S_D,S_E,S_F,S_G silver
    class G_F1,G_F2 gold
    class CON_SM,CON_PBI consume
    class PL_START,PL_DISCOVER,PL_FINAL,PL_REFRESH pipeline
    class DQ_BRZ,DQ_SLV,DQ_GLD dq
    class DQ_STOP stop
    class A1,A2,A3,A4,A5,A6,A7,A8 active
    class B1,B2,B3 paused
    class C1,C2,C3 ready
    class D1,D2 blocked
    class P1,P2,P3,P4,P5 perf
    class R_DEV active
    class R_TEST,R_PROD road
