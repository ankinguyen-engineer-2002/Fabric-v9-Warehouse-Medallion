/// Central measure table for Control Tower KPIs and supporting calculations. Contains no business rows; used only to organize semantic model measures.
table _Measure
	lineageTag: 9901cbcb-f86d-451d-ac5f-06b3eca9cafb

	/// Total consensus forecast quantity in the current filter context.
	measure Qty_Forecast = SUM(FactForecastKpi[QtyForecast])
		formatString: #,0.00
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 35125b31-c1e3-4c6c-ad9e-1a2cb4bcd571

	/// Total actual demand quantity in the current filter context.
	measure Qty_Actual = SUM(FactForecastKpi[QtyActual])
		formatString: #,0.00
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 541c994e-70a1-49aa-b846-ba0e3d9d0f08

	/// Total signed forecast error, stored as Forecast minus Actual. Positive values indicate over-forecast.
	measure Qty_Bias =
			
			SUM(FactForecastKpi[QtyFcstError])
		formatString: #,0
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 7a991851-9819-4703-8d30-ef1e663a094d

		annotation PBI_FormatHint = {"isDecimal":true}

	/// Total naive forecast quantity used as a baseline comparison against the consensus forecast.
	measure Qty_NForecast = SUM(FactForecastKpi[QtyNaiveForecast])
		formatString: #,0.00
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: ceaaaafe-b13c-4499-9a00-6f4e06c9af85

	/// Total absolute forecast error used for wMAPE, MAPE, and forecast accuracy calculations.
	measure Qty_Abs_Bias = SUM(FactForecastKpi[QtyAbsFcstError])
		formatString: #,0
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: ecb1376f-d25b-4350-989d-5d2e84cf9331

		annotation PBI_FormatHint = {"isDecimal":true}

	/// Total signed naive forecast error used to evaluate baseline forecast performance.
	measure Qty_NBias = [Qty_NForecast]-[Qty_Actual]
		formatString: #,0
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 444950c4-69d0-465c-b814-c9039b01b8cf

		annotation PBI_FormatHint = {"isDecimal":true}

	/// Total absolute naive forecast error used for naive wMAPE and process value add calculations.
	measure Qty_Abs_NBias = SUM(FactForecastKpi[QtyAbsNaiveFcstError])
		formatString: #,0
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: eb589d3c-765d-4786-99b1-0f1182c0ed58

		annotation PBI_FormatHint = {"isDecimal":true}

	/// Weighted mean absolute percentage error: absolute forecast error divided by actual demand.
	measure Pct_wMAPE = ```
			DIVIDE([Qty_Abs_Bias] , [Qty_Actual] , BLANK() ) 
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: ca267324-2416-4b7c-828a-e028ef582c8c

	/// Weighted signed forecast bias percentage: signed forecast error divided by actual demand. Positive values indicate over-forecast.
	measure Pct_MPE = DIVIDE([Qty_Bias] , [Qty_Actual] , BLANK())
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: d24ec69f-1fb6-4f39-8b87-ac263ca6b1b3

	/// Mean absolute percentage error across valid rows where actual demand is nonzero.
	measure Pct_MAPE = AVERAGEX ( FILTER ( FactForecastKpi, FactForecastKpi[ValidActualNonzeroFlag] = 1 ), DIVIDE ( FactForecastKpi[QtyAbsFcstError], FactForecastKpi[QtyActual] ) )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: f0668502-4558-4f26-8ec5-b5af48620dfe

	/// Root mean squared forecast error across valid observations. Penalizes larger forecast misses more heavily.
	measure RMSE = SQRT ( DIVIDE ( SUM ( FactForecastKpi[QtySquaredFcstError] ), SUM ( FactForecastKpi[ValidObsFlag] ) ) )
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: e0cb0013-aa0d-4cdd-9a10-561d4d6f77c7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Process value add: naive wMAPE minus forecast wMAPE. Positive values indicate the consensus forecast outperformed the naive baseline.
	measure ProcessValueAdd = ```
			[Pct_NwMAPE] - [Pct_wMAPE] 
			```
		formatString: #,0.0%;-#,0.0%;#,0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 5987e7eb-c766-429a-9e05-1f1c5f1d9415

	/// Naive weighted mean absolute percentage error: absolute naive forecast error divided by actual demand.
	measure Pct_NwMAPE = ```
			DIVIDE([Qty_Abs_NBias] , [Qty_Actual] , BLANK() ) 
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 79ee241b-5ecc-423e-bd74-20e930008ccc

	/// Forecast accuracy percentage calculated as 1 minus wMAPE. Future fiscal periods return blank.
	measure Pct_ForecastAccuracy = ```
			
			VAR MaxDateInRow = MAX('FactForecastKpi'[FSCMonthLast])
			VAR CurrentDate = TODAY()
			VAR wMAPE = [Pct_wMAPE]
			
			RETURN
			IF (
			    -- Điều kiện: Nếu ngày tháng dự báo nhỏ hơn hoặc bằng hôm nay
			    MaxDateInRow <= CurrentDate,
			    
			    -- Thực hiện công thức gốc, cho phép kết quả âm
			    1 - wMAPE,
			    
			    -- Nếu là ngày tương lai thì để trống
			    BLANK()
			)
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 94c6b6e9-6c2e-41d8-8770-e7461489a823

	/// Forecast accuracy for the prior fiscal month window. For multi-month selections, compares against the same-length prior fiscal month window.
	measure Pct_ForecastAccuracy_lm = ```
			
			VAR CurrentMonths =
			    SELECTCOLUMNS(
			        VALUES(DimCalendar[FSCMonthYearNum]),
			        "CurrentMonthKey", DimCalendar[FSCMonthYearNum]
			    )
			
			VAR PrevMonths =
			    SELECTCOLUMNS(
			        GENERATE(
			            CurrentMonths,
			            VAR CurrentMonthKey = [CurrentMonthKey]
			            RETURN
			                SELECTCOLUMNS(
			                    TOPN(
			                        1,
			                        FILTER(
			                            ALL(DimCalendar[FSCMonthYearNum]),
			                            DimCalendar[FSCMonthYearNum] < CurrentMonthKey
			                        ),
			                        DimCalendar[FSCMonthYearNum], DESC
			                    ),
			                    "PrevMonthKey", DimCalendar[FSCMonthYearNum]
			                )
			        ),
			        "num_fsc_month_year", [PrevMonthKey]
			    )
			
			RETURN
			CALCULATE(
			    [Pct_ForecastAccuracy],
			    REMOVEFILTERS(DimCalendar),
			    TREATAS(
			        PrevMonths,
			        DimCalendar[FSCMonthYearNum]
			    )
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: e18d193b-099a-4baf-a6ea-dcc767b604d1

	/// Change in forecast accuracy versus the prior fiscal month comparison window.
	measure Delta_ForecastAccuracy_MoM = ```
			[Pct_ForecastAccuracy] - [Pct_ForecastAccuracy_lm] 
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: a3b6afbe-0713-4a5c-81b1-c10c73935697

	/// Difference between wMAPE and absolute signed bias percentage. Highlights error remaining after directional bias is removed.
	measure TrueError = ```
			[Pct_wMAPE] - ABS([Pct_MPE]) 
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 94e71636-1231-440a-ab3a-132c362eaf87

	/// wMAPE filtered to Lag-0 forecast horizon.
	measure Pct_wMAPE_Lag0 = CALCULATE([Pct_wMAPE] , DimForecastHorizon[Rank] = 1 )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 3b751690-9b6f-4223-a31f-630782adb717

	/// wMAPE filtered to Lag-1 forecast horizon.
	measure Pct_wMAPE_Lag1 = CALCULATE([Pct_wMAPE] , DimForecastHorizon[Rank] = 2 )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 334a2353-49d6-4440-afe6-dd2251e9ad84

	/// wMAPE filtered to Lag-2 forecast horizon.
	measure Pct_wMAPE_Lag2 = CALCULATE([Pct_wMAPE] , DimForecastHorizon[Rank] = 3 )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: af24ff9f-4943-4517-94ab-a01e3b471e12

	/// wMAPE filtered to Lag-3 forecast horizon.
	measure Pct_wMAPE_Lag3 = CALCULATE([Pct_wMAPE] , DimForecastHorizon[Rank] = 4 )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: d6b32e4d-b4fa-4a34-b5b1-73729888668d

	/// wMAPE filtered to Lag-4 forecast horizon.
	measure Pct_wMAPE_Lag4 = CALCULATE([Pct_wMAPE] , DimForecastHorizon[Rank] = 5 )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: e95bfa46-a86e-45c3-9148-8f7de155ccde

	/// Actual demand quantity filtered to the Lag-0 horizon. Legacy name references the prior 2-week label.
	measure Qty_Actual_2W = CALCULATE(SUM(FactForecastKpi[QtyActual]), DimForecastHorizon[Rank] = 1)
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: d7e9ff03-a5a4-42c7-882a-57a2a0ee5171

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Total quantity from flat forecast/actual records where status is Invoice.
	measure Qt_Invoice = ```
			
			    CALCULATE(
			        SUM('FactForecastActual'[Qty]),
			        'FactForecastActual'[StatusCode] = "Invoice"
			    )
			```
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 49bef55c-2e44-49a5-b3ba-ad80faaf4266

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Total quantity from flat forecast/actual records where status is Open Order.
	measure Qt_Open_SO = ```
			
