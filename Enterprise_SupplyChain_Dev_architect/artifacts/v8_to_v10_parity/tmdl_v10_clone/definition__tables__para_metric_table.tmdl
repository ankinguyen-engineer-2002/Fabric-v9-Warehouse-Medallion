/// Parameter table used by report visuals to switch or display selected forecast accuracy metrics. Supports metric-driven layouts and narrative visuals.
table para_metric_table
	lineageTag: 8d993d3b-dac0-4b8a-b4d7-e7d01bbe6d32

	/// Display name of the selectable metric used by report visuals.
	column para_metric_table
		lineageTag: de53a66c-80b2-466b-89fe-156f4749cc88
		summarizeBy: none
		sourceColumn: [Value1]
		sortByColumn: 'para_metric_table Order'

		relatedColumnDetails
			groupByColumn: 'para_metric_table Fields'

		annotation SummarizationSetBy = Automatic

	/// Field parameter reference to the selected Control Tower metric measure.
	column 'para_metric_table Fields'
		isHidden
		lineageTag: 7963518f-3d68-4b7e-bf77-b21cb53e9001
